{
  "buildCommand": "npx expo export -p web && cp -r site dist/site",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/site", "destination": "/site/index.html" },
    { "source": "/privacy", "destination": "/site/privacy.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/refresh-feed",
      "schedule": "0 9 * * *"
    }
  ]
}
